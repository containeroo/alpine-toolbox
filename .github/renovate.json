{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "semanticCommits": "enabled",
  "dependencyDashboard": true,
  "separateMajorMinor": false,
  "labels": ["dependency"],
  "minimumReleaseAge": "1 day",
  "prCreation": "not-pending",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)Dockerfile$/",
        "/(^|/)Dockerfile\\.[^/]*$/"
      ],
      "matchStrings": [
        "#\\srenovate:\\sdatasource=(?<datasource>.*?) depName=(?<depName>.*?)( versioning=(?<versioning>.*?))?( extractVersion=(?<extractVersion>.*?))?\\s(ENV|ARG) .*?_VERSION(\\s+|=)(?<currentValue>.*)\\s"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": ["docker", "github-releases", "github-tags"],
      "matchUpdateTypes": ["patch", "minor", "major"],
      "enabled": true
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["alpine"],
      "matchUpdateTypes": ["patch"],
      "addLabels": ["bump:patch"]
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["alpine"],
      "matchUpdateTypes": ["minor"],
      "addLabels": ["bump:minor"]
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["alpine"],
      "matchUpdateTypes": ["major"],
      "addLabels": ["bump:major"]
    },
    {
      "matchDatasources": ["github-releases", "github-tags"],
      "matchPackageNames": ["mikefarah/yq", "openSUSE/catatonit"],
      "matchUpdateTypes": ["patch"],
      "addLabels": ["bump:patch"]
    },
    {
      "matchDatasources": ["github-releases", "github-tags"],
      "matchPackageNames": ["mikefarah/yq", "openSUSE/catatonit"],
      "matchUpdateTypes": ["minor"],
      "addLabels": ["bump:minor"]
    },
    {
      "matchDatasources": ["github-releases", "github-tags"],
      "matchPackageNames": ["mikefarah/yq", "openSUSE/catatonit"],
      "matchUpdateTypes": ["major"],
      "addLabels": ["bump:major"]
    }
  ],
  "pre-commit": {
    "enabled": true
  }
}
